<local:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FoodDrinkApp"
             x:Class="FoodDrinkApp.SettingsPage"
             Title="Settings">

    <ScrollView BackgroundColor="{AppThemeBinding Light=#FEFAF3, Dark=#0F1210}">
        <VerticalStackLayout Padding="16,12,16,24" Spacing="14">

            <Label Text="Accessibility"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#1E1510, Dark=#F5EDE4}"
                   Margin="4,4,0,4" />

            <!-- ===== Theme card ===== -->
            <Border StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E201D}"
                    Padding="18">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Appearance"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}" />
                    <Label Text="Switch between system, light, and dark themes."
                           FontSize="12"
                           TextColor="{AppThemeBinding Light=#BFA58E, Dark=#8A7A68}" />
                    <Picker x:Name="ThemePicker"
                            Title="Choose app theme"
                            SelectedIndexChanged="OnThemeChanged"
                            SemanticProperties.Hint="Switch between system, light, and dark theme">
                        <Picker.Items>
                            <x:String>Use system theme</x:String>
                            <x:String>Light theme</x:String>
                            <x:String>Dark theme</x:String>
                        </Picker.Items>
                    </Picker>
                </VerticalStackLayout>
            </Border>

            <!-- ===== Large text card ===== -->
            <Border StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E201D}"
                    Padding="18">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Large text"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#2F7A4F, Dark=#8CE6A1}" />
                            <Label Text="Increases text size across all pages."
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#BFA58E, Dark=#8A7A68}" />
                        </VerticalStackLayout>
                        <Switch x:Name="LargeTextSwitch"
                                Grid.Column="1"
                                Toggled="OnLargeTextToggled"
                                SemanticProperties.Hint="Increase text size across the current session" />
                    </Grid>

                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light=#F0E8DC, Dark=#3A3028}" />

                    <Label x:Name="LargeTextPreviewTitle"
                           Text="Large text preview"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#B87A4A, Dark=#D9A67A}" />
                    <Label x:Name="LargeTextPreviewBody"
                           Text="Turn on the switch to enlarge this preview and other page text."
                           FontSize="15"
                           TextColor="{AppThemeBinding Light=#6E5A47, Dark=#C8B8A5}" />
                </VerticalStackLayout>
            </Border>

            <!-- Status -->
            <Label x:Name="SettingsStatusLabel"
                   Text="Settings ready."
                   FontSize="12"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#BFA58E, Dark=#8A7A68}"
                   Margin="8,2,0,0" />
        </VerticalStackLayout>
    </ScrollView>
</local:BasePage>
