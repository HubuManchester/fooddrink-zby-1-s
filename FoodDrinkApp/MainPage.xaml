<local:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:FoodDrinkApp.Models"
             xmlns:local="clr-namespace:FoodDrinkApp"
             xmlns:l10n="clr-namespace:FoodDrinkApp.Services"
             x:Class="FoodDrinkApp.MainPage"
             Shell.NavBarIsVisible="False"
             Title="NutriBite">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto"
          BackgroundColor="{AppThemeBinding Light=#FEFAF3, Dark=#0F1210}"
          Padding="0">

        <!-- Hero header -->
        <Grid Padding="20,24,20,16"
              BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#191B18}">
            <Grid.Shadow>
                <Shadow Brush="#0C000000" Offset="0,1" Radius="4" Opacity="0.08" />
            </Grid.Shadow>
            <Grid RowDefinitions="Auto,Auto" RowSpacing="2">
                <Label Text="{l10n:Translate MainTitle}"
                       FontSize="26" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}" />
                <Label Grid.Row="1"
                       Text="{l10n:Translate MainTagline}"
                       FontSize="13"
                       TextColor="{AppThemeBinding Light=#9A7B63, Dark=#BFA58E}" />
            </Grid>
        </Grid>

        <!-- Recommended for you — horizontal scroll -->
        <VerticalStackLayout Grid.Row="1" Margin="0,8,0,0" Spacing="4">
            <Label Text="{l10n:Translate MainRecommended}"
                   FontSize="15" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#3A2518, Dark=#D8C0A0}"
                   Margin="20,0,0,0" />
            <ScrollView Orientation="Horizontal"
                        HorizontalScrollBarVisibility="Never"
                        Padding="20,0">
                <HorizontalStackLayout x:Name="RecommendedItems" Spacing="10" />
            </ScrollView>
        </VerticalStackLayout>

        <!-- Category filter chips -->
        <ScrollView Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalScrollBarVisibility="Never"
                    Margin="0,2,0,0"
                    Padding="20,0">
            <HorizontalStackLayout x:Name="CategoryChips"
                                   Spacing="8"
                                   Padding="0,8,0,6" />
        </ScrollView>

        <!-- Food list -->
        <RefreshView Grid.Row="3" x:Name="FoodRefreshView" Refreshing="OnRefreshing">
            <CollectionView x:Name="FoodCollection"
                            SelectionMode="None"
                            ItemsLayout="VerticalList"
                            Margin="0,4,0,0">
                <CollectionView.EmptyView>
                    <Label Text="{l10n:Translate MainEmptyList}"
                           FontSize="14"
                           TextColor="{AppThemeBinding Light=#BFA58E, Dark=#8A7A68}"
                           HorizontalTextAlignment="Center"
                           Margin="0,40,0,0" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:FoodItem">
                        <Border StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E201D}"
                                Padding="0"
                                Margin="16,0,16,10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#12000000" Offset="0,2" Radius="8" Opacity="0.10" />
                            </Border.Shadow>
                            <Grid ColumnDefinitions="5,*" MinimumHeightRequest="90">
                                <BoxView Color="{AppThemeBinding Light=#D9472B, Dark=#FF7D55}" />
                                <Grid Grid.Column="1" Padding="14,12"
                                      RowDefinitions="Auto,Auto,Auto"
                                      ColumnDefinitions="*,Auto"
                                      RowSpacing="6">
                                    <Label Text="{Binding Name}"
                                           FontSize="17" FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#1E1510, Dark=#F5EDE4}"
                                           LineBreakMode="TailTruncation" />
                                    <Border Grid.Column="1" StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light=#FFF2E0, Dark=#3D2E1C}"
                                            Padding="10,4" VerticalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="20" />
                                        </Border.StrokeShape>
                                        <Label Text="{Binding CaloriesLabel}"
                                               FontSize="12" FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light=#C75B1A, Dark=#FFB87A}" />
                                    </Border>
                                    <Label Grid.Row="1" Grid.ColumnSpan="2"
                                           Text="{Binding MacroSummary}"
                                           FontSize="13"
                                           TextColor="{AppThemeBinding Light=#5A7A5A, Dark=#7CB87C}" />
                                    <HorizontalStackLayout Grid.Row="2" Grid.ColumnSpan="2"
                                                           Spacing="8" VerticalOptions="End">
                                        <Border StrokeThickness="1"
                                                Stroke="{AppThemeBinding Light=#F0D6B8, Dark=#4A3A28}"
                                                BackgroundColor="{AppThemeBinding Light=#FFF8F0, Dark=#2A2218}"
                                                Padding="8,3">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="6" />
                                            </Border.StrokeShape>
                                            <Label Text="{Binding Category}"
                                                   FontSize="11"
                                                   TextColor="{AppThemeBinding Light=#B87A4A, Dark=#D9A67A}" />
                                        </Border>
                                    </HorizontalStackLayout>
                                </Grid>
                            </Grid>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnFoodCardTapped"
                                                      CommandParameter="{Binding Id}" />
                            </Border.GestureRecognizers>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Search + FAB -->
        <Grid Grid.Row="4"
              ColumnDefinitions="*,Auto"
              Padding="16,0,16,16"
              Margin="0,-60,0,0"
              ColumnSpacing="12">
            <Border StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#292B28}"
                    Padding="0" VerticalOptions="End">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#18000000" Offset="0,4" Radius="16" Opacity="0.14" />
                </Border.Shadow>
                <SearchBar x:Name="SearchFoodBar"
                           Placeholder="{l10n:Translate MainSearchPlaceholder}"
                           TextChanged="OnSearchTextChanged"
                           SearchButtonPressed="OnSearchButtonPressed"
                           TextColor="{AppThemeBinding Light=#3A2518, Dark=#F5EDE4}"
                           PlaceholderColor="{AppThemeBinding Light=#BFA58E, Dark=#8A7A68}"
                           BackgroundColor="Transparent"
                           CancelButtonColor="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}" />
            </Border>
            <Button Grid.Column="1"
                    Text="+"
                    FontSize="26" FontAttributes="Bold"
                    WidthRequest="52" HeightRequest="52"
                    CornerRadius="26" Padding="0"
                    BackgroundColor="{AppThemeBinding Light=#D9472B, Dark=#FF6B3D}"
                    TextColor="#FFFFFF"
                    Clicked="OnAddClicked"
                    VerticalOptions="End" />
        </Grid>
    </Grid>
</local:BasePage>
