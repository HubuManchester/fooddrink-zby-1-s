<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FoodDrinkApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:FoodDrinkApp"
    xmlns:l10n="clr-namespace:FoodDrinkApp.Services"
    FlyoutBehavior="Disabled"
    Shell.BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#191B18}"
    Shell.ForegroundColor="{AppThemeBinding Light=#D9472B, Dark=#FFB15D}"
    Shell.TitleColor="{AppThemeBinding Light=#3A2518, Dark=#F5EDE4}"
    Shell.UnselectedColor="{AppThemeBinding Light=#BFA58E, Dark=#8A7A68}"
    Shell.TabBarBackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#191B18}"
    Shell.TabBarForegroundColor="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}"
    Shell.TabBarTitleColor="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}"
    Shell.TabBarUnselectedColor="{AppThemeBinding Light=#BFA58E, Dark=#8A7A68}">

    <TabBar x:Name="MainTabs">
        <ShellContent
            Title="{l10n:Translate TabFoods}"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />
        <ShellContent
            Title="{l10n:Translate TabDevices}"
            ContentTemplate="{DataTemplate local:HardwarePage}"
            Route="HardwarePage" />
        <ShellContent
            Title="{l10n:Translate TabSettings}"
            ContentTemplate="{DataTemplate local:SettingsPage}"
            Route="SettingsPage" />
    </TabBar>
</Shell>
