<local:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FoodDrinkApp"
             xmlns:l10n="clr-namespace:FoodDrinkApp.Services"
             x:Class="FoodDrinkApp.AddItemPage"
             Title="{l10n:Translate AddTitle}">

    <Grid RowDefinitions="*,Auto"
          BackgroundColor="{AppThemeBinding Light=#FEFAF3, Dark=#0F1210}">
        <ScrollView>
            <VerticalStackLayout Padding="16,12,16,16" Spacing="14">
                <Label Text="{l10n:Translate AddTitle}"
                       FontSize="22" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#1E1510, Dark=#F5EDE4}"
                       Margin="4,4,0,4" />

                <Border StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E201D}"
                        Padding="18">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="14">
                        <Label Text="{l10n:Translate AddBasicInfo}"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}" />
                        <Entry x:Name="NameEntry"
                               Placeholder="{l10n:Translate AddNamePlaceholder}" />
                        <Picker x:Name="CategoryPicker"
                                Title="{l10n:Translate AddCategoryTitle}">
                            <Picker.Items>
                                <x:String>Breakfast</x:String>
                                <x:String>Lunch</x:String>
                                <x:String>Dinner</x:String>
                                <x:String>Snack</x:String>
                                <x:String>Drink</x:String>
                            </Picker.Items>
                        </Picker>
                        <Editor x:Name="DescriptionEditor"
                                Placeholder="{l10n:Translate AddDescriptionPlaceholder}"
                                AutoSize="TextChanges" HeightRequest="90" />
                    </VerticalStackLayout>
                </Border>

                <Border StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E201D}"
                        Padding="18">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="14">
                        <Label Text="{l10n:Translate AddNutritionData}"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#2F7A4F, Dark=#8CE6A1}" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Entry x:Name="CaloriesEntry"
                                   Placeholder="{l10n:Translate AddCaloriesPlaceholder}"
                                   Keyboard="Numeric" />
                            <Entry x:Name="ProteinEntry" Grid.Column="1"
                                   Placeholder="{l10n:Translate AddProteinPlaceholder}"
                                   Keyboard="Numeric" />
                        </Grid>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Entry x:Name="CarbsEntry"
                                   Placeholder="{l10n:Translate AddCarbsPlaceholder}"
                                   Keyboard="Numeric" />
                            <Entry x:Name="FatEntry" Grid.Column="1"
                                   Placeholder="{l10n:Translate AddFatPlaceholder}"
                                   Keyboard="Numeric" />
                        </Grid>
                        <Entry x:Name="AllergyEntry"
                               Placeholder="{l10n:Translate AddAllergyPlaceholder}" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <VerticalStackLayout Grid.Row="1" Spacing="8"
                             Padding="16,0,16,16"
                             BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#191B18}">
            <Border x:Name="ValidationPanel" IsVisible="False"
                    StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#FFF0EC, Dark=#3D1E1A}"
                    Padding="14">
                <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                <Label x:Name="ValidationLabel"
                       TextColor="{AppThemeBinding Light=#C0392B, Dark=#FFB4A6}"
                       FontSize="13" FontAttributes="Bold" />
            </Border>
            <Button Text="{l10n:Translate AddSaveButton}"
                    FontSize="16" FontAttributes="Bold"
                    BackgroundColor="{AppThemeBinding Light=#D9472B, Dark=#FF6B3D}"
                    TextColor="#FFFFFF" CornerRadius="12" HeightRequest="50"
                    Clicked="OnSaveClicked" />
        </VerticalStackLayout>
    </Grid>
</local:BasePage>
